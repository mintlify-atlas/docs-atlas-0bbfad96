  "keyFeatures": [
    "AI-powered course matching and recommendations",
    "Comprehensive university and course search with advanced filtering",
    "Student accommodation discovery and comparison",
    "Interactive career exploration and gamified career arcade",
    "Social groups, messaging, and campus feed",
    "Event calendar and university societies/sports",
    "Budget planning and cost estimation tools",
    "Comparison tools for courses, universities, and accommodation",
    "3D multiplayer game hub with avatar customization",
    "Journey tracking with stage-based progression",
    "Real-time chat and multiplayer interactions",
    "Customizable widget-based hub dashboard"
  ],
  "publicApiSurface": [
    "ChapterApp - Main SwiftUI app entry point",
    "MasterTabView - Tab-based navigation system",
    "AppContainer.shared - Dependency injection container",
    "AuthManager.shared - Authentication and user management",
    "NavigationRouter.shared - Navigation state management",
    "GameManager.shared - Game world state management",
    "CourseDataServiceV2 - Course data operations",
    "UniversityDataServiceV2 - University data operations",
    "CareerPathsManager - Career exploration data",
    "GroupChatViewModel - Messaging functionality",
    "WhatsOnManager - Events and activities",
    "ChapterWidgetManager - Hub widget system",
    "AccommodationV2Manager - Housing search",
    "ShortlistV2Manager - User shortlist management",
    "CalendarEvent - Event data model",
    "UniversityV2 - University data model",
    "Course_V2 - Course data model",
    "GroupUser - User profile model",
    "GroupChat - Chat group model"
  ]
